# Application
APP_NAME=ProductFlow
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=productflow
POSTGRES_PASSWORD=productflow
POSTGRES_DB=productflow

# Derived automatically; override only if using a full connection URL
# DATABASE_URL=postgresql+psycopg://productflow:productflow@localhost:5432/productflow

# SQLAlchemy pool (tuned for read-heavy catalog workloads)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
